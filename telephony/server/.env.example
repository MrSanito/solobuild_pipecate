# telephony - Environment Variables
# Copy this file to .env and fill in your API keys

# Daily (Transport)
DAILY_API_KEY=
# Optional: leave empty to create a new room
# DAILY_ROOM_URL=


# Twilio (Transport)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=


# Google (STT/LLM/TTS/Realtime)
GOOGLE_API_KEY=
GOOGLE_MODEL=
GOOGLE_VOICE_ID=


