# pipecatEnglish - Environment Variables
# Copy this file to .env and fill in your API keys

# Daily (Transport)
DAILY_API_KEY=

# Environment mode: "local" for development, "production" for cloud deployment
ENV=local

# Local bot server URL (where bot.py runs)
LOCAL_SERVER_URL=http://localhost:7860

# Pipecat Cloud (only needed for production)
PIPECAT_API_KEY=
PIPECAT_AGENT_NAME=pipecatEnglish


# Google (STT/LLM/TTS/Realtime)
GOOGLE_API_KEY=
GOOGLE_MODEL=
GOOGLE_VOICE_ID=


